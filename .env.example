# Multi-AI Relay Hub — Environment Variables
# Copy this file to `.env` and uncomment the lines you want to change.

# Timeout (seconds) for each AI subprocess (default: 600)
# RELAY_TIMEOUT_SEC=600

# Maximum context characters sent to each AI (default: 32000)
# MAX_CONTEXT_CHARS=32000

# Relay mode: "readonly" (default) or "full"
#   readonly = AIs cannot write/delete files (bypass-permissions disabled)
#   full     = AIs can use tools freely (bypass-permissions enabled)
# RELAY_MODE=readonly
